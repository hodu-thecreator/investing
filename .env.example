# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  Stock Agent 환경변수 설정
#  이 파일을 .env 로 복사한 뒤 값을 채우세요
#  cp .env.example .env
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── 텔레그램 봇 ─────────────────────────────
# 1. @BotFather 에게 /newbot 명령으로 봇 생성
# 2. 발급받은 토큰을 아래에 입력
TELEGRAM_BOT_TOKEN=8389712132:AAHcJdHnDWX_Odre3C0eYzEDz_p5FzH6WMM

# 3. 봇에게 아무 메시지를 보낸 뒤:
#    python telegram_notifier.py --get-chat-id
#    명령으로 Chat ID를 확인해서 아래에 입력
TELEGRAM_CHAT_ID=8011598577

# ── FRED API (경제지표) ──────────────────────
# https://fred.stlouisfed.org/docs/api/api_key.html 에서 무료 발급
# JOLTS, CPI, 소비자심리/신뢰지수, 금리, 마진부채 데이터에 필요
FRED_API_KEY=your_fred_api_key_here
